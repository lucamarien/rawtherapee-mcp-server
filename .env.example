# RawTherapee MCP Server — Environment Variables
# Copy this file to .env or set these as environment variables.
# All values shown are defaults — uncomment and modify as needed.

# Path to rawtherapee-cli binary.
# Auto-detected on Windows (Program Files), macOS (/Applications), and Linux (/usr/bin).
# Set this if RawTherapee is installed in a non-standard location.
# RT_CLI_PATH=/usr/bin/rawtherapee-cli

# Default output directory for processed images.
# RT_OUTPUT_DIR=~/Pictures/rawtherapee-mcp-output

# Directory for temporary preview images (cleaned up automatically).
# RT_PREVIEW_DIR=/tmp

# Directory for user-created custom PP3 templates.
# RT_CUSTOM_TEMPLATES_DIR=~/.rawtherapee-mcp/custom_templates

# Maximum width/height for preview images in pixels (100-10000).
# Larger values give more detail but increase MCP response size.
# RT_PREVIEW_MAX_WIDTH=1200

# Default JPEG quality for processed output (1-100).
# RT_JPEG_QUALITY=95

# Logging level for server diagnostics (DEBUG, INFO, WARNING, ERROR).
# Set to DEBUG for troubleshooting.
# RT_LOG_LEVEL=WARNING

# ── v1.0.3: Film Simulation / LUT Support ───────────────────────────────────
# Directory containing HaldCLUT PNG/TIFF files for film simulation.
# Download RT's official Film Simulation Collection and point here.
# Required for list_luts, apply_lut, preview_lut, preview_lut_comparison.
# RT_HALDCLUT_DIR=~/Pictures/HaldCLUT

# ── v1.0.3: Adobe Lens Correction Profiles (optional) ───────────────────────
# Directory containing .lcp files for apply_lens_correction (mode='lcp').
# RT_LCP_DIR=

# ── v1.0.3: Lensfun Database (optional override) ────────────────────────────
# Directory containing Lensfun XML database files for check_lens_support.
# Auto-detected per platform (/usr/share/lensfun on Linux; RT install on Win/Mac).
# Override if auto-detection fails.
# RT_LENSFUN_DIR=/usr/share/lensfun
